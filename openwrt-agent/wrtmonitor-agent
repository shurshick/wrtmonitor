#!/bin/sh
set -eu

# Used by sourced libraries from lib/*.sh.
# shellcheck disable=SC2034
AGENT_VERSION="0.3.0-rc5"
# shellcheck disable=SC2034
CONFIG="wrtmonitor.main"

SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s\n' "$0")"
case "$SCRIPT_PATH" in
    */*) SCRIPT_DIR="${SCRIPT_PATH%/*}" ;;
    *) SCRIPT_DIR="." ;;
esac

if [ -n "${WRTMONITOR_LIB_DIR:-}" ]; then
    LIB_DIR="$WRTMONITOR_LIB_DIR"
elif [ -d "$SCRIPT_DIR/lib" ]; then
    LIB_DIR="$SCRIPT_DIR/lib"
else
    LIB_DIR="/usr/lib/wrtmonitor"
fi

load_lib() {
    name="$1"
    path="$LIB_DIR/$name"
    if [ ! -r "$path" ]; then
        echo "FATAL: failed to load WrtMonitor library: $path" >&2
        exit 1
    fi
    # shellcheck disable=SC1090
    . "$path" || {
        echo "FATAL: failed to load WrtMonitor library: $path" >&2
        exit 1
    }
}

load_lib common.sh
load_lib status.sh
load_lib update.sh
load_lib telemetry.sh
load_lib capabilities.sh
load_lib diagnostics.sh
load_lib commands.sh
load_lib api.sh

main "$@"
