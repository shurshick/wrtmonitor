#!/bin/sh /etc/rc.common

START=95
STOP=10

PID_FILE="/var/run/wrtmonitor-agent.pid"

start() {
  if [ -r "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "wrtmonitor already running"
    return 0
  fi
  echo "Starting wrtmonitor"
  /usr/bin/wrtmonitor-agent daemon >/dev/null 2>&1 &
  echo "$!" > "$PID_FILE"
}

stop() {
  if [ -r "$PID_FILE" ]; then
    pid="$(cat "$PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      echo "Stopping wrtmonitor"
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
  fi
}

restart() {
  stop
  start
}

status() {
  if [ -r "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "running"
    return 0
  fi
  echo "stopped"
  return 1
}
